<!doctype html>
<html><head><title>Admin Dashboard</title><link rel="stylesheet" href="/public/css/styles.css"/></head>
<body>
<header class="topbar"><h2>Admin Dashboard</h2><a href="/">Public Map</a> <a href="/admin/users">Users</a></header>
<section class="cards">
  <div>Total Properties: <%= stats.totalProperties %></div>
  <div>Total Value: $<%= Number(stats.totalValue).toLocaleString() %></div>
  <div>Residential: <%= stats.residentialCount %></div>
  <div>Commercial: <%= stats.commercialCount %></div>
  <div>Businesses: <%= stats.totalBusinesses %></div>
</section>
<section>
  <h3>Data</h3>
  <p>The map image is fixed (bundled with the app).</p>
  <form action="/admin/maps/reset" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"/><button type="submit">Reset all polygons</button></form>
  <p><a href="/admin/export/json">Download JSON export</a></p>
</section>
<section><h3>Recent Properties</h3><ul><% recentProperties.forEach((p)=>{ %><li><%= p.parcel_id %> - <%= p.name %> (<%= p.status %>)</li><% }) %></ul></section>
<section><h3>Audit Logs</h3><ul><% audit.forEach((a)=>{ %><li><%= a.created_at %> | <%= a.action %> | <%= a.table_name %>#<%= a.record_id %></li><% }) %></ul></section>
</body></html>
