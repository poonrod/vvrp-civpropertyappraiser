<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Staff login — SAPA</title>
  <link rel="stylesheet" href="/public/css/styles.css" />
</head>
<body>
  <main class="login-card-wrap">
    <div class="login-card">
      <div class="login-card__logo">
        <img src="/public/images/sapa-logo.png" alt="San Andreas Property Appraisal" width="240" height="82" decoding="async" />
      </div>
      <h1 class="login-card__title">Staff access</h1>
      <% if (typeof flashError !== 'undefined' && flashError && flashError.length) { %>
        <p class="login-card__error" role="alert"><%= flashError[0] %></p>
      <% } %>
      <p class="login-card__hint">Sign in with Discord to open the admin tools.</p>
      <a class="btn btn-primary login-card__cta" href="<%= authUrl %>">Continue with Discord</a>
    </div>
  </main>
</body>
</html>
