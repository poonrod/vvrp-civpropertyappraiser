<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="csrf-token" content="<%= csrfToken %>" />
  <link rel="stylesheet" href="/public/css/styles.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
  <title>San Andreas Property Appraiser</title>
</head>
<body class="layout-map">
  <div class="toast-container" id="toastContainer"></div>
  <header class="site-header">
    <div class="site-header__inner">
      <div class="site-header__lead">
        <%- include('partials/brand') %>
      </div>
      <nav class="site-nav" aria-label="Account">
        <% if (user) { %>
          <a class="btn btn-ghost" href="/admin">Admin</a>
          <form class="inline" action="/auth/logout" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit">Sign out</button>
          </form>
        <% } else { %>
          <a class="btn btn-primary" href="/auth/login">Staff login</a>
        <% } %>
      </nav>
    </div>
  </header>

  <div class="map-toolbar">
    <input class="input-search" id="searchInput" type="search" autocomplete="off" placeholder="Search owner, parcel, address, postal code (e.g. 5000), business…" aria-label="Search properties" />
    <button type="button" class="btn btn-sm" id="filterToggle" title="Advanced Filters">Filters</button>
    <button type="button" class="btn btn-sm" id="viewToggle" title="Toggle Map/Table">Table</button>
    <button type="button" class="btn btn-sm" id="legendToggle">Legend</button>
    <button type="button" class="btn btn-accent btn-sm" id="openRequestForm">Request Appraisal</button>
    <button type="button" class="btn btn-sm" id="bookmarkBtn" title="Save/load views" style="display:none">Views</button>
    <button type="button" class="btn btn-sm" id="leaderboardBtn" title="Leaderboard" style="display:none">Board</button>
    <button type="button" class="btn btn-sm" id="gazetteBtn" title="Gazette" style="display:none">Gazette</button>
    <button type="button" class="btn btn-sm" id="analyticsBtn" title="Market Analytics" style="display:none">Analytics</button>
    <button type="button" class="btn btn-sm" id="proximityBtn" title="Nearby properties" style="display:none">Nearby</button>
    <button type="button" class="btn btn-sm" id="timelineBtn" title="Historical Timeline" style="display:none">Timeline</button>
    <button type="button" class="btn btn-sm btn-accent" id="surveyDistrictBtn" title="Draw a district zone on the map" style="display:none">Zoning Tool</button>
    <button type="button" class="btn btn-sm" id="shortcutsHelp" title="Keyboard shortcuts (?)">?</button>
  </div>

  <div class="filter-bar hidden" id="filterBar">
    <div class="filter-bar__inner">
      <div class="filter-group">
        <span class="field-label">Type</span>
        <label class="filter-check"><input type="checkbox" value="Residential" class="filter-type" checked /> Residential</label>
        <label class="filter-check"><input type="checkbox" value="Commercial" class="filter-type" checked /> Commercial</label>
        <label class="filter-check"><input type="checkbox" value="Government" class="filter-type" checked /> Government</label>
        <label class="filter-check"><input type="checkbox" value="Vacant Land" class="filter-type" checked /> Vacant Land</label>
      </div>
      <div class="filter-group">
        <span class="field-label">Status</span>
        <select id="filterStatus" class="filter-select">
          <option value="">All</option>
          <option value="Owned">Owned</option>
          <option value="For Sale">For Sale</option>
          <option value="Foreclosed">Foreclosed</option>
          <option value="Government Seized">Government Seized</option>
          <option value="Requires Survey">Requires Survey</option>
        </select>
      </div>
      <div class="filter-group">
        <span class="field-label">Zone</span>
        <select id="filterZone" class="filter-select">
          <option value="">All Zones</option>
        </select>
      </div>
      <div class="filter-group">
        <span class="field-label">Value Range</span>
        <input type="number" id="filterMinValue" placeholder="Min $" class="filter-input" />
        <input type="number" id="filterMaxValue" placeholder="Max $" class="filter-input" />
      </div>
      <button type="button" class="btn btn-compact" id="clearFilters">Clear All</button>
    </div>
  </div>

  <div class="table-view hidden" id="tableView">
    <div class="table-view__header">
      <span class="table-view__count" id="tableCount"></span>
      <button type="button" class="btn btn-compact" id="exportCsvBtn">Export CSV</button>
      <button type="button" class="btn btn-compact" id="backToMapBtn">Back to Map</button>
    </div>
    <div class="table-view__wrap">
      <table class="property-table" id="propertyTable">
        <thead>
          <tr>
            <th data-sort="parcel_id" class="sortable">Parcel</th>
            <th data-sort="name" class="sortable">Name</th>
            <th data-sort="address" class="sortable">Address</th>
            <th data-sort="type" class="sortable">Type</th>
            <th data-sort="owner_name" class="sortable">Owner</th>
            <th data-sort="assessed_value" class="sortable">Value</th>
            <th data-sort="annual_tax" class="sortable">Tax</th>
            <th data-sort="status" class="sortable">Status</th>
          </tr>
        </thead>
        <tbody id="propertyTableBody"></tbody>
      </table>
    </div>
    <div class="table-pagination" id="tablePagination"></div>
  </div>

  <div id="leaderboardOverlay" class="modal hidden">
    <div class="shortcuts-card" style="max-width:500px">
      <h3>Appraiser Leaderboard</h3>
      <div id="leaderboardContent"><p class="module-empty">Loading...</p></div>
      <button type="button" class="btn btn-compact" id="closeLeaderboard">Close</button>
    </div>
  </div>

  <div id="gazetteOverlay" class="modal hidden">
    <div class="shortcuts-card" style="max-width:600px;max-height:80vh;overflow:auto">
      <h3>Property Gazette</h3>
      <div id="gazetteContent"><p class="module-empty">Loading...</p></div>
      <button type="button" class="btn btn-compact" id="closeGazette">Close</button>
    </div>
  </div>

  <div id="bookmarkOverlay" class="modal hidden">
    <div class="shortcuts-card" style="max-width:400px">
      <h3>Saved Views</h3>
      <div id="bookmarkList"><p class="module-empty">Loading...</p></div>
      <div class="module-form-body" style="margin-top:12px">
        <input type="text" id="bookmarkNameInput" placeholder="View name" />
        <button type="button" class="btn btn-compact btn-primary" id="saveBookmarkBtn">Save Current View</button>
      </div>
      <button type="button" class="btn btn-compact" id="closeBookmark" style="margin-top:12px">Close</button>
    </div>
  </div>

  <div class="seasonal-banner hidden" id="seasonalBanner"></div>

  <div id="analyticsOverlay" class="modal hidden">
    <div class="shortcuts-card" style="max-width:700px;max-height:85vh;overflow:auto">
      <h3>Market Analytics</h3>
      <div id="analyticsContent"><p class="module-empty">Loading...</p></div>
      <button type="button" class="btn btn-compact" id="closeAnalytics">Close</button>
    </div>
  </div>

  <div id="proximityOverlay" class="modal hidden">
    <div class="shortcuts-card" style="max-width:500px">
      <h3>Proximity Search</h3>
      <div class="module-form-body" style="margin-bottom:12px">
        <label class="field-label">Select a property first, then set radius:</label>
        <div style="display:flex;gap:8px;align-items:center">
          <input type="number" id="proximityRadius" value="500" min="50" max="5000" step="50" style="width:100px" />
          <span class="text-muted">meters</span>
          <button type="button" class="btn btn-compact btn-primary" id="runProximityBtn">Search</button>
        </div>
      </div>
      <div id="proximityResults"><p class="module-empty">Select a property on the map, then click Search</p></div>
      <button type="button" class="btn btn-compact" id="closeProximity" style="margin-top:12px">Close</button>
    </div>
  </div>

  <div id="timelineControl" class="timeline-control hidden">
    <label class="field-label" style="color:var(--text-muted);font-size:11px">Timeline</label>
    <input type="range" id="timelineSlider" min="0" max="100" value="100" style="width:200px" />
    <span id="timelineDate" class="text-muted" style="font-size:11px">Now</span>
    <button type="button" class="btn btn-compact" id="timelineClose" title="Close timeline">&times;</button>
  </div>

  <div id="districtModal" class="modal hidden">
    <div class="shortcuts-card" style="max-width:420px">
      <h3>Survey New District</h3>
      <p class="text-muted" style="font-size:12px;margin-bottom:12px">Draw a polygon on the map first, then fill in the details below.</p>
      <div class="module-form-body">
        <input type="text" id="districtName" placeholder="District name" />
        <input type="text" id="districtDesc" placeholder="Description (optional)" />
        <div style="display:flex;gap:8px">
          <div style="flex:1"><label class="field-label">Color</label><input type="color" id="districtColor" value="#3498db" style="width:100%;height:32px;border:1px solid var(--border);border-radius:4px;background:var(--bg-deep)" /></div>
          <div style="flex:1"><label class="field-label">Tax Multiplier</label><input type="number" id="districtTaxMult" value="1.0" step="0.1" min="0" /></div>
        </div>
        <div>
          <label class="field-label">HOA Fee ($/mo) — applies to all residential properties in this district</label>
          <input type="number" id="districtHoaFee" value="0" step="1" min="0" placeholder="0 = no HOA" />
        </div>
        <button type="button" class="btn btn-primary btn-compact" id="saveDistrictBtn">Save District</button>
      </div>
      <button type="button" class="btn btn-compact" id="closeDistrictModal" style="margin-top:12px">Cancel</button>
    </div>
  </div>

  <div id="shortcutsOverlay" class="modal hidden">
    <div class="shortcuts-card">
      <h3>Keyboard Shortcuts</h3>
      <div class="shortcuts-grid">
        <div class="shortcut-row"><kbd>S</kbd> or <kbd>/</kbd> Focus search</div>
        <div class="shortcut-row"><kbd>N</kbd> New property (staff)</div>
        <div class="shortcut-row"><kbd>F</kbd> Toggle filters</div>
        <div class="shortcut-row"><kbd>T</kbd> Toggle table view</div>
        <div class="shortcut-row"><kbd>L</kbd> Toggle legend</div>
        <div class="shortcut-row"><kbd>Esc</kbd> Close panel/modal</div>
        <div class="shortcut-row"><kbd>?</kbd> This help</div>
      </div>
      <button type="button" class="btn btn-compact" id="closeShortcuts">Close</button>
    </div>
  </div>

  <main class="map-stage">
    <aside id="legend" class="legend hidden" aria-live="polite">
      <div><strong style="color:var(--text)">Land use</strong></div>
      <div>Residential — blue fill</div>
      <div>Commercial — orange</div>
      <div>Government — green</div>
      <div>Vacant land — gray</div>
      <div style="margin-top:8px"><strong style="color:var(--text)">Status borders</strong></div>
      <div>For sale — yellow</div>
      <div>Foreclosed — red</div>
      <div>Requires survey — light red</div>
    </aside>

    <div id="map" role="application" aria-label="Property map"></div>
    <aside id="propertyPanel" class="panel hidden" aria-label="Property details"></aside>

    <% if (user && (user.role === 'admin' || user.role === 'appraiser' || user.role === 'clerk')) { %>
    <div id="propertyModal" class="modal hidden">
      <form id="propertyForm">
        <input type="hidden" id="geojsonInput" />
        <input type="hidden" id="editPropertyId" value="" />
        <h3 id="propertyModalTitle">New property</h3>
        <div class="work-order-group" id="workOrderGroup">
          <span class="field-label">Work Order</span>
          <select id="workOrderSelect" aria-label="Work order">
            <option value="">— None —</option>
          </select>
        </div>
        <p id="parcelDisplayRow" class="parcel-display-row hidden"><strong>Parcel</strong> <span id="parcelDisplay"></span></p>
        <input name="name" placeholder="Property name" required />
        <select name="type" id="propertyTypeSelect" aria-label="Property type"><option>Residential</option><option>Commercial</option><option>Government</option><option>Vacant Land</option></select>
        <input name="address" placeholder="RP address" required />
        <div id="singleOwnerFields" class="owner-fields-group">
          <select name="owner_type" id="ownerTypeSelect" aria-label="Owner type"><option>Individual</option><option>Business</option></select>
          <input name="owner_name" placeholder="Owner name" />
          <div id="businessNameGroup" class="business-name-group hidden">
            <div class="autocomplete-wrap">
              <input type="text" id="businessNameInput" name="business_name" placeholder="Business / Company name" autocomplete="off" />
              <input type="hidden" id="businessIdInput" name="business_id" value="" />
              <div id="businessSuggestions" class="autocomplete-dropdown hidden"></div>
            </div>
          </div>
        </div>
        <div id="residentialOwnersBlock" class="owner-fields-group hidden">
          <span class="field-label">Owners (Residential — multiple for RP)</span>
          <div id="coOwnersList" class="co-owners-list"></div>
          <button type="button" class="btn btn-ghost btn-compact" id="addCoOwner">Add owner</button>
        </div>
        <input name="purchase_price" placeholder="Purchase price" type="number" step="0.01" />
        <input name="purchase_date" type="date" />
        <input name="assessed_value" placeholder="Assessed value" type="number" step="0.01" id="assessedValueInput" />
        <div class="sqft-group">
          <input name="square_footage" placeholder="Square footage" type="number" step="1" id="sqftInput" />
          <span class="tax-hint" id="sqftHint"></span>
        </div>
        <div class="tax-zone-group">
          <span class="field-label">Tax Zone</span>
          <select id="taxZoneSelect" aria-label="Tax zone">
            <option value="">— Custom / No zone —</option>
          </select>
        </div>
        <div class="tax-rate-group">
          <span class="field-label" id="taxRateLabel">Property Tax Rate</span>
          <input name="tax_rate" placeholder="Tax rate %" type="number" step="0.01" id="taxRateInput" />
          <span class="tax-hint" id="taxRateHint"></span>
        </div>
        <select name="status" aria-label="Status"><option>Owned</option><option>For Sale</option><option>Foreclosed</option><option>Government Seized</option><option>Requires Survey</option></select>
        <label class="checkbox-label"><input type="checkbox" id="hideDetailsPublic" /> Hide appraiser details from the public (parcel outline only)</label>
        <textarea name="notes" placeholder="Notes" rows="3"></textarea>
        <div id="formModulesContainer" class="form-modules-container hidden"></div>
        <button type="submit" id="propertyFormSubmit">Save property</button>
        <button type="button" id="markSurveyBtn" class="btn btn-survey-save">Mark for Survey</button>
        <button type="button" id="closeModal">Cancel</button>
      </form>
    </div>
    <% } %>

    <div id="requestModal" class="modal hidden">
      <form id="requestForm">
        <h3>Request Property Appraisal</h3>
        <input name="discord_name" placeholder="Your name (Discord / RP)" required id="reqDiscordName" />
        <select id="reqTypeSelect" aria-label="Property type">
          <option value="Residential">Residential</option>
          <option value="Commercial">Commercial</option>
        </select>

        <div id="reqResidentialFields">
          <span class="field-label">Owners</span>
          <div id="reqCoOwnersList" class="co-owners-list"></div>
          <button type="button" class="btn btn-ghost btn-compact" id="reqAddCoOwner">Add owner</button>
        </div>

        <div id="reqCommercialFields" class="hidden">
          <input name="business_name" placeholder="Business name" id="reqBusinessName" />
          <select name="owner_type" id="reqOwnerType" aria-label="Owner type"><option>Individual</option><option>Business</option></select>
          <input name="owner_name" placeholder="Owner name" id="reqOwnerName" />
        </div>

        <input name="address" placeholder="Address" id="reqAddress" />
        <input name="postal" placeholder="Postal code" id="reqPostal" />
        <input name="purchase_price" placeholder="Purchase value ($)" type="number" step="0.01" id="reqPurchasePrice" />
        <input name="square_footage" placeholder="Square footage" type="number" step="1" id="reqSqft" />
        <textarea name="notes" placeholder="Additional notes" rows="3" id="reqNotes"></textarea>
        <button type="submit" class="btn btn-primary">Submit Request</button>
        <button type="button" class="btn" id="closeRequestModal">Cancel</button>
      </form>
    </div>
  </main>

  <script>window.SAPA_CONFIG = <%- JSON.stringify(config || {}) %>; window.SAPA_USER = <%- JSON.stringify(user || null) %>; window.SAPA_TAX_RATES = <%- JSON.stringify(taxRates || {}) %>; window.SAPA_TAX_PRESETS = <%- JSON.stringify(taxPresets || []) %>; window.SAPA_PRICE_PER_SQFT = <%= typeof pricePerSqft !== 'undefined' && pricePerSqft ? pricePerSqft : 0 %>; window.SAPA_MODULES = <%- JSON.stringify(modules || {}) %>;</script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>
  <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
  <script src="/public/js/main.js"></script>
</body>
</html>
