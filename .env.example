NODE_ENV=production
PORT=3000
BASE_URL=http://localhost:3000

# Trust first reverse-proxy hop by default (fixes express-rate-limit behind Evennode).
# Set TRUST_PROXY=false if you have no proxy (plain localhost). Optional: TRUST_PROXY=2 for double proxy.
# TRUST_PROXY=false

MONGODB_URI=mongodb://127.0.0.1:27017/sapa

# Evennode / TLS: download evennode.pem from the dashboard, place it in the app root (do not commit).
# Then set e.g. MONGODB_TLS_CA_FILE=evennode.pem
# Password in URI must be percent-encoded (JS encodeURIComponent is not enough for ! and * — use %21 %2A etc.).
# MONGODB_TLS_CA_FILE=

# Optional: use in-memory sessions instead of Mongo (not for production multi-instance)
# USE_MEMORY_SESSION=true

SESSION_SECRET=replace_with_long_random_secret
# Optional: set false if you must use plain HTTP without Secure cookies
# SESSION_COOKIE_SECURE=false
CSRF_COOKIE_NAME=sapa_csrf

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

DEFAULT_ADMIN_DISCORD_ID=123456789012345678
