NODE_ENV=production
PORT=3000
BASE_URL=http://localhost:3000

# Trust first reverse-proxy hop by default (fixes express-rate-limit behind Evennode).
# On Evennode: delete TRUST_PROXY or set TRUST_PROXY=1. Do not use false/0 (breaks X-Forwarded-For).
# Set TRUST_PROXY=false only for plain localhost with no X-Forwarded-For. Optional: TRUST_PROXY=2 for double proxy.
# TRUST_PROXY=false

MONGODB_URI=mongodb://127.0.0.1:27017/sapa

# Evennode / TLS: repo includes evennode-mongodb-ca.pem (public Mongo CA). Optional override:
# MONGODB_TLS_CA_FILE=evennode.pem  (file next to package.json on the server)
# Or omit MONGODB_TLS_CA_FILE — the app uses bundled evennode-mongodb-ca.pem when present.
# Password in URI must be percent-encoded (JS encodeURIComponent is not enough for ! and * — use %21 %2A etc.).
# MONGODB_TLS_CA_FILE=

# Optional: use in-memory sessions instead of Mongo (not for production multi-instance)
# USE_MEMORY_SESSION=true

SESSION_SECRET=replace_with_long_random_secret
# Plain HTTP (e.g. http://yoursite.evennode.com): cookies cannot use Secure. Either set
# BASE_URL=http://... (app treats http:// as non-Secure cookies) or SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_SECURE=false
CSRF_COOKIE_NAME=sapa_csrf

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

DEFAULT_ADMIN_DISCORD_ID=123456789012345678
